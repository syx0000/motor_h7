+# EditorConfig for STM32H7 FOC Motor Control Project
+# https://editorconfig.org
+
+root = true
+
+# All files
+[*]
+charset = utf-8
+insert_final_newline = true
+trim_trailing_whitespace = true
+
+# C/C++ source files
+[*.{c,h,cpp,hpp}]
+indent_style = tab
+indent_size = 4
+end_of_line = crlf
+
+# Markdown files
+[*.md]
+indent_style = space
+indent_size = 2
+end_of_line = lf
+trim_trailing_whitespace = false
+
+# YAML files
+[*.{yml,yaml}]
+indent_style = space
+indent_size = 2
+end_of_line = lf
+
+# JSON files
+[*.json]
+indent_style = space
+indent_size = 2
+end_of_line = lf
+
+# Makefile
+[Makefile]
+indent_style = tab
+end_of_line = lf
+
+# Git files
+[.gitignore]
+end_of_line = lf
+
+# Keil project files
+[*.{uvprojx,uvoptx}]
+end_of_line = crlf
