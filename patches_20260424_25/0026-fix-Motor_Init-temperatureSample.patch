+		float r1_ntc = 10.0f * adc1_voltage / (3.3f - adc1_voltage);
+		if(r1_ntc > 0.01f) // 防止log(0)
+			TEMP_MOTOR_filter1 = 1.0f / ((1.0f / 298.15f) + (logf(r1_ntc / 10.0f) / 3950.0f)) - 273.15f;
+		else
+			TEMP_MOTOR_filter1 = 25.0f;
+	}
