# Git attributes for STM32H7 FOC Motor Control Project

# Auto detect text files and perform LF normalization
* text=auto

# C/C++ source files - CRLF for Windows/Keil compatibility
*.c text eol=crlf
*.h text eol=crlf
*.cpp text eol=crlf
*.hpp text eol=crlf

# Markdown and documentation - LF
*.md text eol=lf
*.txt text eol=lf

# Configuration files - LF
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Keil MDK project files - CRLF
*.uvprojx text eol=crlf
*.uvoptx text eol=crlf
*.uvguix.* text eol=crlf
*.sct text eol=crlf

# STM32CubeMX files - CRLF
*.ioc text eol=crlf

# Assembly files - CRLF
*.s text eol=crlf
*.asm text eol=crlf

# Linker scripts - CRLF
*.ld text eol=crlf

# Binary files - no conversion
*.bin binary
*.hex binary
*.elf binary
*.axf binary
*.o binary
*.lib binary
*.a binary
*.so binary
*.dll binary
*.exe binary

# Image files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary

# Archive files
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary
